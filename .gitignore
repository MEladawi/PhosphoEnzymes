# Generated outputs (legacy script pipeline)
data_out/

# BiocCheck output directory
*.BiocCheck/

# Source snapshots in inst/extdata -- the committed pinned set is finalized later;
# for now keep only the docs and the frozen KinHub snapshot under version control.
inst/extdata/*
!inst/extdata/SOURCES.md
!inst/extdata/kinhub_kinases.html

# Ignore dotfiles (.DS_Store, .Rhistory, .RData, .Rproj.user/, etc.), but keep the
# repo's own meta files that must stay under version control.
.*
!.gitignore
!.gitattributes
!.Rbuildignore
!.github/
